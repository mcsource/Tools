# ============================================================
# YouTube Video Analyzer — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- Google AI (Gemini 2.0 Flash) ---
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-key

# --- Supabase (signalstrike-testing-ryan) ---
# Find at: https://supabase.com/dashboard/project/gyhdtbspbkxkjjbtsakx/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://gyhdtbspbkxkjjbtsakx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- App Access Password ---
APP_PASSWORD=your-chosen-password

# --- App URL (update after Vercel deploy) ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
